# 环境变量配置示例
# 复制此文件为 .env.local 并填入实际值

# ========================================
# 应用配置
# ========================================
NODE_ENV=development
PORT=3000

# ========================================
# Better Auth 配置
# ========================================
# 认证密钥（至少 32 字符，生产环境必须修改）
BETTER_AUTH_SECRET=your-secret-key-at-least-32-characters-long-change-me

# 应用基础 URL
BETTER_AUTH_URL=http://localhost:3000

# ========================================
# 数据库配置
# ========================================
DATABASE_URL=postgresql://oksai:oksai_dev_password@localhost:5432/oksai

# 数据库连接参数（可选）
DB_HOST=localhost
DB_PORT=5432
DB_USER=oksai
DB_PASSWORD=oksai_dev_password
DB_NAME=oksai

# ========================================
# SMTP 邮件配置
# ========================================
# SMTP 服务器地址
SMTP_HOST=smtp.example.com

# SMTP 端口（通常 587 用于 TLS，465 用于 SSL）
SMTP_PORT=587

# 是否使用安全连接（465 端口通常为 true）
SMTP_SECURE=false

# SMTP 用户名和密码
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-smtp-password

# 发件人信息
SMTP_FROM=noreply@example.com
SMTP_FROM_NAME=oksai.cc

# ========================================
# OAuth 配置（可选）
# ========================================

# Google OAuth
# 创建应用：https://console.cloud.google.com/apis/credentials
# 回调 URL：http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth
# 创建应用：https://github.com/settings/developers
# 回调 URL：http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ========================================
# CORS 配置（可选）
# ========================================
# 允许的前端域名（多个用逗号分隔）
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ========================================
# Redis 配置（用于分布式缓存）
# ========================================
# Redis 连接 URL（生产环境推荐）
REDIS_URL=redis://localhost:6379

# 是否启用 Redis 缓存（true/false）
# 如果未设置或为 false，将使用内存缓存
REDIS_ENABLED=true
