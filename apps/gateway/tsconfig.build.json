{
  "extends": ["@oksai/tsconfig/nestjs-esm.json", "@oksai/tsconfig/build.json"],
  "compilerOptions": {
    "outDir": "./dist",
    "baseUrl": "./",
    "noEmit": false
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/*.e2e.ts",
    "test"
  ]
}
