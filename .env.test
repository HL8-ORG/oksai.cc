# 测试环境变量配置

# ========================================
# 应用配置
# ========================================
NODE_ENV=test
PORT=3001

# ========================================
# Better Auth 配置
# ========================================
BETTER_AUTH_SECRET=test-secret-key-at-least-32-characters-long-for-testing-only
BETTER_AUTH_URL=http://localhost:3001

# ========================================
# 测试数据库配置
# ========================================
# 使用与开发环境相同的数据库实例，但使用不同的数据库名
DATABASE_URL=postgresql://oksai:oksai_dev_password@localhost:5432/oksai_test

DB_HOST=localhost
DB_PORT=5432
DB_USER=oksai
DB_PASSWORD=oksai_dev_password
DB_NAME=oksai_test

# ========================================
# OAuth 配置（测试）
# ========================================
GOOGLE_CLIENT_ID=test-google-client-id
GOOGLE_CLIENT_SECRET=test-google-client-secret
GITHUB_CLIENT_ID=test-github-client-id
GITHUB_CLIENT_SECRET=test-github-client-secret
