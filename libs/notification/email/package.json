{
  "name": "@oksai/email",
  "version": "1.0.0",
  "description": "Email service for oksai.cc",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "default": "./dist/index.js"
    }
  },
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --tsconfig tsconfig.build.json",
    "build:watch": "tsup src/index.ts --format cjs,esm --dts --watch",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "clean": "pnpm exec rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "nodemailer": "^6.9.16"
  },
  "devDependencies": {
    "@types/node": "^20.19.9",
    "@types/nodemailer": "^6.4.17",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "~5.9.3"
  }
}
