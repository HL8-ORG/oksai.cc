{
  "name": "@oksai/database",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "clean": "pnpm exec rimraf dist coverage"
  },
  "dependencies": {
    "@mikro-orm/core": "catalog:",
    "@mikro-orm/postgresql": "catalog:",
    "@mikro-orm/reflection": "catalog:",
    "@nestjs/common": "catalog:",
    "@oksai/context": "workspace:*",
    "@oksai/kernel": "workspace:*",
    "pino": "catalog:",
    "postgres": "catalog:"
  },
  "devDependencies": {
    "@oksai/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "rimraf": "^6.0.1",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
