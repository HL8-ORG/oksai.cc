{
  "name": "@oksai/eda",
  "version": "0.2.0",
  "description": "事件驱动架构模块 - Outbox/Inbox、Kafka、事件总线",
  "license": "AGPL-3.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "format": "biome format --write .",
    "clean": "pnpm exec rimraf dist coverage"
  },
  "dependencies": {
    "@mikro-orm/core": "catalog:",
    "@nestjs/common": "catalog:",
    "@nestjs/core": "catalog:",
    "@oksai/config": "workspace:*",
    "@oksai/context": "workspace:*",
    "@oksai/contracts": "workspace:*",
    "@oksai/kernel": "workspace:*",
    "@oksai/logger": "workspace:*"
  },
  "optionalDependencies": {
    "kafkajs": "^2.2.4",
    "prom-client": "^15.1.3"
  },
  "peerDependencies": {
    "@mikro-orm/core": "^6.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@oksai/tsconfig": "workspace:*",
    "vitest": "^3.0.0"
  }
}
