{
  "name": "@oksai/logger",
  "version": "0.2.0",
  "description": "日志模块 - 基于 Pino 的结构化日志，集成多租户上下文",
  "license": "AGPL-3.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm exec tsup src/index.ts --format cjs,esm --dts --external @oksai/config --external @oksai/constants --external @oksai/context",
    "build:watch": "pnpm exec tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "format": "biome format --write .",
    "clean": "pnpm exec rimraf dist coverage"
  },
  "dependencies": {
    "@nestjs/common": "catalog:",
    "@nestjs/core": "catalog:",
    "@oksai/config": "workspace:*",
    "@oksai/constants": "workspace:*",
    "@oksai/context": "workspace:*",
    "nestjs-pino": "catalog:",
    "pino": "catalog:"
  },
  "devDependencies": {
    "@oksai/tsconfig": "workspace:*",
    "pino-pretty": "catalog:",
    "tsup": "catalog:"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@oksai/context": "workspace:*"
  },
  "engines": {
    "node": ">=20"
  }
}
