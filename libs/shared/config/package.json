{
  "name": "@oksai/config",
  "version": "0.2.0",
  "description": "配置管理模块 - 基于 @nestjs/config 增强，支持 zod schema 验证、类型安全访问",
  "license": "AGPL-3.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm exec tsup src/index.ts --format cjs,esm --dts --external @oksai/domain-core",
    "build:watch": "pnpm exec tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "format": "biome format --write .",
    "clean": "pnpm exec rimraf dist coverage"
  },
  "dependencies": {
    "@nestjs/common": "catalog:",
    "@nestjs/config": "catalog:",
    "@oksai/domain-core": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@oksai/tsconfig": "workspace:*",
    "tsup": "catalog:"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "zod": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
