{
  "name": "@oksai/nestjs-better-auth",
  "version": "1.0.0",
  "description": "Better Auth integration for NestJS - Oksai",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "default": "./dist/index.js"
    }
  },
  "private": true,
  "license": "MIT",
  "keywords": [
    "nestjs",
    "better-auth",
    "auth",
    "authentication"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --external @nestjs/graphql --external @nestjs/websockets",
    "build:watch": "tsup src/index.ts --format cjs,esm --dts --watch",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "@nestjs/common": "catalog:",
    "@nestjs/core": "catalog:",
    "better-auth": "catalog:",
    "express": "^5.2.1",
    "reflect-metadata": "catalog:"
  },
  "peerDependenciesMeta": {
    "@nestjs/graphql": {
      "optional": true
    },
    "@nestjs/websockets": {
      "optional": true
    },
    "graphql": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/testing": "catalog:",
    "@nestjs/websockets": "catalog:",
    "@types/body-parser": "^1.19.6",
    "@types/express": "catalog:",
    "graphql": "^16.13.0",
    "reflect-metadata": "catalog:",
    "rimraf": "^6.1.3",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
