{
  "name": "@oksai/nestjs-utils",
  "version": "0.1.0",
  "description": "NestJS 工具函数",
  "license": "AGPL-3.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "pnpm exec tsup src/index.ts --format cjs,esm && pnpm exec tsc -p tsconfig.build.json --emitDeclarationOnly",
    "build:watch": "pnpm exec tsup src/index.ts --format cjs,esm --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "format": "biome format --write .",
    "clean": "pnpm exec rimraf dist coverage"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "catalog:",
    "@nestjs/core": "catalog:",
    "@nestjs/swagger": "catalog:",
    "@oksai/tsconfig": "workspace:*",
    "tsup": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=20"
  }
}
