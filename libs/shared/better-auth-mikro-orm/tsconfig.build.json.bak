{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"composite": false,
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"removeComments": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"outDir": "./dist",
		"rootDir": "./src"
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist", "src/**/*.spec.ts"]
}
