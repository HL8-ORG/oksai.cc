{
  "extends": "../../tsconfig.base.json",
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts"],
  "compilerOptions": {
    "composite": true,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "references": [
    {
      "path": "../shared/repository"
    },
    {
      "path": "../shared/kernel"
    },
    {
      "path": "../shared/event-store"
    },
    {
      "path": "../database"
    }
  ]
}
