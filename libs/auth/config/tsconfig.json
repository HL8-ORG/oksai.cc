{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@oksai/database": ["../../database/src"],
      "@oksai/database/schema": ["../../database/src/schema"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
