{
  "name": "@oksai/iam-domain",
  "version": "0.1.0",
  "private": true,
  "description": "IAM 领域模型层 - 聚合根、值对象、领域事件、仓储接口",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "clean": "pnpm exec rimraf dist coverage"
  },
  "dependencies": {
    "@oksai/kernel": "workspace:*"
  },
  "devDependencies": {
    "@oksai/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "rimraf": "^6.0.1",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
